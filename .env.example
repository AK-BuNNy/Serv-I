# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cybersec_ai

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── AI Provider: openai | gemini | claude ──
AI_PROVIDER=openai

# Embedding provider (defaults to AI_PROVIDER; falls back to openai when claude is selected)
EMBEDDING_PROVIDER=openai

# Vector embedding dimensions (1536 for OpenAI/Claude fallback, 768 for Gemini)
EMBEDDING_DIMS=1536

# ── Provider API Keys (set the ones you need) ──
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_anthropic_key

# ── Dashboard ──
NEXT_PUBLIC_API_URL=http://localhost:3000